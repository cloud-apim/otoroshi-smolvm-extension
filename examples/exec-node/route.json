{
  "_comment": "Drop this object into an Otoroshi route's 'plugins' array. The backend call is fully replaced by the smolvm function.",
  "plugin": "cp:otoroshi_plugins.com.cloud.apim.otoroshi.extensions.smolvm.plugins.SmolVmFunctionBackend",
  "enabled": true,
  "config": {
    "mode": "exec",
    "hosts": ["http://127.0.0.1:8080"],
    "image": "smolvm-exec-node:latest",
    "exec_command": ["node", "/app/handler.js"],
    "request_timeout": 30000,
    "boot_timeout": 60000,
    "isolation": "ephemeral"
  }
}
